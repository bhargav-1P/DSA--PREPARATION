// RETRIEVAL: Squares of a Sorted Array (#977)
// ============================================
// PATTERN: Two Pointers (Ends to Center)
// STORY: "Two Giants"
// Two giants stand at opposite ends of the sorted array.
// I compare their squared heights. The taller giant goes
// to the last empty spot in my answer array. The used
// giant leaves, so I move that pointer inward. Repeat.
// TIME: O(n) | SPACE: O(n)
// STATUS: Day 16 retrieval — zero peeks ✅

var sortedSquares = function(nums) {
    let low=0;
    let high=nums.length-1;
    const result= new Array();
    for(let i=nums.length-1;i>=0;i--){
        const leftSquare=nums[low]**2;
        const rightSquare=nums[high]**2;
        if(leftSquare>rightSquare){
            result[i]=leftSquare
            low++
        }else{
            result[i]=rightSquare;
            high--
        }
    }
    return result;
};
console.log(sortedSquares([-4,-1,0,3,10])); // [0,1,9,16,100]
console.log(sortedSquares([-7,-3,2,3,11])); // [4,9,9,49,121]

